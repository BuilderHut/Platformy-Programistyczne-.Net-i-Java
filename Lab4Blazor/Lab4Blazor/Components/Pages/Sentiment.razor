@page "/sentiment"
@rendermode InteractiveServer

<PageTitle>Sentiment Analysis</PageTitle>

<h1>Sentiment Analysis</h1>

<p>Write a tweet or short text and check its sentiment.</p>

<textarea class="form-control"
          rows="5"
          placeholder="Type your text here..."
          @bind="userInput">
</textarea>

<br />

<button class="btn btn-primary" @onclick="AnalyzeSentiment">
    Analyze
</button>

@if (prediction != null)
{
    <div class="mt-4">
        <h3>Result</h3>

        <p>
            <strong>Prediction:</strong>
            @prediction.PredictedLabel
            @GetSentimentName(prediction.PredictedLabel)
        </p>

        <p>
            <strong>Confidence:</strong>
            @(prediction.Score.Max() * 100)%
        </p>
    </div>
}

@code {
    private string userInput = "";
    private MLModel.ModelOutput? prediction;

    private void AnalyzeSentiment()
    {
        if (!string.IsNullOrWhiteSpace(userInput))
        {
            var input = new MLModel.ModelInput
            {
                Text_of_the_tweet_ = userInput
            };

            prediction = MLModel.Predict(input);
        }
    }

    private string GetSentimentName(float label)
    {
        return label switch
        {
            0 => "(negative)",
            4 => "(positive)",
            _ => "(unknown)"
        };
    }
}